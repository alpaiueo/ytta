<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Stream Player UI</title>
    <style>
        :root {
            --bg-body: #0d1017;
            --bg-card: #161923;
            --bg-hover: #232734;
            --border-color: #2b3040;
            --text-main: #ffffff;
            --text-muted: #8b949e;
            --accent-red: #ff4d4d;
            --accent-red-bg: rgba(255, 77, 77, 0.1);
            --font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            font-family: var(--font-family);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        /* Main Container */
        .player-container {
            width: 100%;
            max-width: 900px;
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        /* Header Section */
        .header {
            padding: 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .title-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .title-row h1 {
            font-size: 20px;
            font-weight: 600;
        }

        .live-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--accent-red);
            border: 1px solid rgba(255, 77, 77, 0.3);
            background-color: var(--accent-red-bg);
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
        }

        .live-dot {
            width: 8px;
            height: 8px;
            background-color: var(--accent-red);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.4; }
            100% { opacity: 1; }
        }

        .tags-row {
            display: flex;
            gap: 10px;
        }

        .tag {
            background-color: #232734;
            color: var(--text-muted);
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* Video Area */
        .video-wrapper {
            position: relative;
            width: 100%;
            aspect-ratio: 16 / 9;
            background-color: #000;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .video-top-bar, .video-bottom-bar {
            padding: 16px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            z-index: 2; /* Penting agar tombol berada di atas iframe */
            position: relative; /* Diperlukan untuk z-index */
            background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 100%);
        }

        .video-bottom-bar {
            background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 100%);
            align-items: center;
        }

        /* Overlay Buttons */
        .overlay-btn {
            background-color: rgba(22, 25, 35, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--text-main);
            padding: 10px 16px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s;
        }

        .overlay-btn:hover {
            background-color: rgba(43, 48, 64, 0.9);
        }

        /* Bottom Controls */
        .control-group {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .ctrl-icon {
            background: none;
            border: none;
            color: var(--text-main);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.8;
            transition: opacity 0.2s;
        }

        .ctrl-icon:hover {
            opacity: 1;
        }

        .play-square {
            width: 12px;
            height: 12px;
            background-color: white;
            border-radius: 1px;
        }

        .live-text {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            font-weight: bold;
            color: white;
            margin-left: 8px;
        }

        .live-text .live-dot {
            width: 6px;
            height: 6px;
            background-color: white;
            animation: none;
        }

        .cc-badge {
            border: 1px solid white;
            padding: 2px 4px;
            border-radius: 4px;
            font-size: 10px;
            font-weight: bold;
        }

        /* Footer Section */
        .footer {
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: var(--bg-card);
        }

        .source-selector {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-muted);
            font-size: 14px;
        }

        .source-selector select {
            background-color: #0d1017;
            color: var(--text-main);
            border: 1px solid var(--border-color);
            padding: 8px 12px;
            border-radius: 6px;
            outline: none;
            width: 150px;
            appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 10px center;
            background-size: 16px;
        }

        .action-buttons {
            display: flex;
            gap: 12px;
        }

        .btn-action {
            background-color: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s;
        }

        .btn-action:hover {
            background-color: var(--bg-hover);
        }

        .btn-icon-only {
            padding: 8px;
        }

        /* SVGs styling */
        svg {
            width: 16px;
            height: 16px;
            fill: currentColor;
        }
        .ctrl-icon svg {
            width: 20px;
            height: 20px;
        }
    </style>
</head>
<body>

    <div class="player-container">
        <header class="header">
            <div class="title-row">
                <h1>Turkey vs Paraguay</h1>
                <div class="live-badge">
                    <span class="live-dot"></span> Live Now
                </div>
            </div>
            <div class="tags-row">
                <span class="tag">Soccer</span>
                <span class="tag">
                    <svg viewBox="0 0 24 24"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/></svg>
                    Jun 20, 2026, 10:00 AM GMT+7
                </span>
            </div>
        </header>

        <div class="video-wrapper">
            
            <iframe 
                src="https://junkieembeds.pages.dev/embed/fox-sports-1" 
                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; border: none;" 
                allow="autoplay; encrypted-media" 
                allowfullscreen>
            </iframe>
            
            <div class="video-top-bar">
                <button class="overlay-btn" id="unmuteBtn">
                    <svg viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
                    <span id="unmuteText">Click to Unmute</span>
                </button>
                <button class="overlay-btn">
                    <svg viewBox="0 0 24 24"><path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/></svg>
                    Copy Embed
                </button>
            </div>

            <div class="video-bottom-bar">
                <div class="control-group">
                    <button class="ctrl-icon"><div class="play-square"></div></button>
                    <button class="ctrl-icon">
                        <svg viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/></svg>
                    </button>
                    <div class="live-text"><span class="live-dot"></span> LIVE</div>
                </div>
                
                <div class="control-group">
                    <button class="ctrl-icon"><span class="cc-badge">CC</span></button>
                    <button class="ctrl-icon">
                        <svg viewBox="0 0 24 24"><path d="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.43-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"/></svg>
                    </button>
                    <button class="ctrl-icon">
                        <svg viewBox="0 0 24 24"><path d="M19 7h-8v6h8V7zm2-4H3c-1.1 0-2 .9-2 2v14c0 1.1.9 1.98 2 1.98h18c1.1 0 2-.88 2-1.98V5c0-1.1-.9-2-2-2zm0 16.01H3V4.98h18v14.03z"/></svg>
                    </button>
                    <button class="ctrl-icon">
                        <svg viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
                    </button>
                </div>
            </div>
        </div>

        <footer class="footer">
            <div class="source-selector">
                <label>Source:</label>
                <select>
                    <option value="fs1">FS1</option>
                    <option value="fs2">FS2</option>
                    <option value="espn">ESPN</option>
                </select>
            </div>
            
            <div class="action-buttons">
                <button class="btn-action btn-icon-only" title="Refresh">
                    <svg viewBox="0 0 24 24"><path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
                </button>
                <button class="btn-action">
                    <svg viewBox="0 0 24 24"><path d="M21 3H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H3V5h18v14z"/></svg>
                    Theater
                </button>
                <button class="btn-action" id="chatBtn">
                    <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 9h12v2H6V9zm8 5H6v-2h8v2zm4-6H6V6h12v2z"/></svg>
                    <span id="chatText">Hide Chat</span>
                </button>
            </div>
        </footer>
    </div>

    <script>
        // Mute Button Toggle
        const unmuteBtn = document.getElementById('unmuteBtn');
        const unmuteText = document.getElementById('unmuteText');
        let isMuted = true;

        unmuteBtn.addEventListener('click', () => {
            isMuted = !isMuted;
            if(isMuted) {
                unmuteText.innerText = "Click to Unmute";
                unmuteBtn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg> <span id="unmuteText">Click to Unmute</span>`;
            } else {
                unmuteBtn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg> <span id="unmuteText">Mute</span>`;
            }
        });

        // Chat Toggle
        const chatBtn = document.getElementById('chatBtn');
        const chatText = document.getElementById('chatText');
        let chatHidden = false;

        chatBtn.addEventListener('click', () => {
            chatHidden = !chatHidden;
            chatText.innerText = chatHidden ? "Show Chat" : "Hide Chat";
        });
    </script>
</body>
</html>
